algoritmo "Verificador_Dividendos"

var
   dy: real

inicio
   escreval("=== Verificador de Dividendos ===")
   escreva("Informe o valor do Dividend Yield (DY): ")
   leia(dy)

   se (dy > 6) entao
      escreval("Estratégia de Renda Passiva OK")
   senao
      se (dy >= 4) e (dy <= 6) entao
         escreval("Atenção: Rendimento Médio")
      senao
         escreval("Rendimento Baixo")
      fimse
   fimse

fimalgoritmo
